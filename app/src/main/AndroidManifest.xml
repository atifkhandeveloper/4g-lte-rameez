            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <activity
            android:name="com.ra.wifi.analyzer.fourg.fiveg.wifidata.speed.ui.AnimationActivity"
