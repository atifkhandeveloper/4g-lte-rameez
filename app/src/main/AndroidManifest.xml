        <activity
            android:name="com.ra.wifi.analyzer.fourg.fiveg.wifidata.speed.ui.SimInfoActivity"
            android:exported="false" />
        <activity
            android:name="com.ra.wifi.analyzer.fourg.fiveg.wifidata.speed.ui.LTEDetailsActivity"
            android:exported="false" />
        <activity
            android:name="com.ra.wifi.analyzer.fourg.fiveg.wifidata.speed.ui.LteSettingsActivity"
