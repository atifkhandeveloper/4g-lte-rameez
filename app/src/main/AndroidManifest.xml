        <!-- android:exported="false" /> -->
        <activity
            android:name="com.ra.wifi.analyzer.fourg.fiveg.wifidata.speed.ui.SelectLangActivity"
            android:exported="false" />
        <activity
            android:name="com.ra.wifi.analyzer.fourg.fiveg.wifidata.speed.ui.BoardingActivity"
            android:exported="false" />
        <activity
